<?xml version="1.0" encoding="UTF-8"?>
<?define ProductVersion = "1.0.0.0" ?>
<?define UpgradeCode = "A1B2C3D4-0000-0000-0000-000000000001" ?>

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="DeepSeek DeskBand"
           Language="1033"
           Codepage="65001"
           Version="$(var.ProductVersion)"
           Manufacturer="DeepSeek"
           UpgradeCode="$(var.UpgradeCode)"
           ProductCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567899"
           InstallerVersion="500"
           Compressed="yes"
           Scope="perMachine">

    <Media Id="1" Cabinet="app.cab" EmbedCab="yes" />

    <!-- 升级检测：自动卸载旧版本 -->
    <MajorUpgrade DowngradeErrorMessage="无法降级到旧版本" />

    <!-- ==================== 启动条件 ==================== -->
    <Launch Condition="Installed OR VersionNT64"
            Message="此软件仅支持 64 位 Windows 系统。" />

    <!-- ==================== 目录结构 ==================== -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="DeepSeek DeskBand">
        <Component Id="ProductComponent" Guid="A1B2C3D4-0001-0001-0001-000000000001">
          <RemoveFile Id="PurgeInstallerFolder"
                      Name="*.*"
                      On="uninstall" />
          <RemoveFolder Id="RemoveINSTALLDIR"
                        On="uninstall" />
        </Component>

        <Component Id="Cmp_DeskBandDll"
                   Guid="*">
          <File Id="Fil_DeepSeekDeskBand.dll"
                Name="DeepSeekDeskBand.dll"
                Source="..\bin\Release\net48\DeepSeekDeskBand.dll"
                KeyPath="yes" />

          <!-- CLSID 主键 -->
          <RegistryKey Root="HKLM"
                       Key="SOFTWARE\Classes\CLSID\{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}"
                       ForceCreateOnInstall="yes"
                       ForceDeleteOnUninstall="yes">
            <RegistryValue Type="string" Value="DeepSeek DeskBand" />
          </RegistryKey>

          <!-- InprocServer32 (Standard .NET COM entries) -->
          <RegistryKey Root="HKLM"
                       Key="SOFTWARE\Classes\CLSID\{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}\InprocServer32"
                       ForceCreateOnInstall="yes"
                       ForceDeleteOnUninstall="yes">
            <RegistryValue Type="string" Value="C:\Windows\System32\mscoree.dll" />
            <RegistryValue Name="Assembly" Type="string" Value="DeepSeekDeskBand" />
            <RegistryValue Name="Class" Type="string" Value="DeepSeekDeskBand.DeskBand" />
            <RegistryValue Name="RuntimeVersion" Type="string" Value="v4.0.30319" />
            <RegistryValue Name="CodeBase" Type="string" Value="[INSTALLDIR]DeepSeekDeskBand.dll" />
            <RegistryValue Name="ThreadingModel" Type="string" Value="Both" />
          </RegistryKey>

          <!-- Assembly version subkey - RegAsm /codebase 会自动创建, .NET COM 解析必需 -->
          <RegistryKey Root="HKLM"
                       Key="SOFTWARE\Classes\CLSID\{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}\InprocServer32\1.0.0.0"
                       ForceCreateOnInstall="yes"
                       ForceDeleteOnUninstall="yes">
            <RegistryValue Name="Assembly" Type="string" Value="DeepSeekDeskBand" />
            <RegistryValue Name="Class" Type="string" Value="DeepSeekDeskBand.DeskBand" />
            <RegistryValue Name="RuntimeVersion" Type="string" Value="v4.0.30319" />
            <RegistryValue Name="CodeBase" Type="string" Value="[INSTALLDIR]DeepSeekDeskBand.dll" />
          </RegistryKey>

          <!-- ProgId under CLSID -->
          <RegistryKey Root="HKLM"
                       Key="SOFTWARE\Classes\CLSID\{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}\ProgId"
                       ForceCreateOnInstall="yes"
                       ForceDeleteOnUninstall="yes">
            <RegistryValue Type="string" Value="DeepSeek.DeskBand.1" />
          </RegistryKey>

          <!-- Implemented Categories -->
          <RegistryKey Root="HKLM"
                       Key="SOFTWARE\Classes\CLSID\{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}\Implemented Categories\{00021492-0000-0000-C000-000000000046}"
                       ForceCreateOnInstall="yes"
                       ForceDeleteOnUninstall="yes" />

          <!-- ProgID -->
          <RegistryKey Root="HKLM"
                       Key="SOFTWARE\Classes\DeepSeek.DeskBand.1"
                       ForceCreateOnInstall="yes"
                       ForceDeleteOnUninstall="yes">
            <RegistryValue Type="string" Value="DeepSeek DeskBand" />
          </RegistryKey>

          <RegistryKey Root="HKLM"
                       Key="SOFTWARE\Classes\DeepSeek.DeskBand.1\CLSID"
                       ForceCreateOnInstall="yes"
                       ForceDeleteOnUninstall="yes">
            <RegistryValue Type="string" Value="{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}" />
          </RegistryKey>

          <!-- 无版本号 ProgID 别名 -->
          <RegistryKey Root="HKLM"
                       Key="SOFTWARE\Classes\DeepSeek.DeskBand"
                       ForceCreateOnInstall="yes"
                       ForceDeleteOnUninstall="yes">
            <RegistryValue Type="string" Value="DeepSeek DeskBand" />
          </RegistryKey>

          <RegistryKey Root="HKLM"
                       Key="SOFTWARE\Classes\DeepSeek.DeskBand\CurVer"
                       ForceCreateOnInstall="yes"
                       ForceDeleteOnUninstall="yes">
            <RegistryValue Type="string" Value="DeepSeek.DeskBand.1" />
          </RegistryKey>
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="ProductFeature"
             Title="DeepSeek DeskBand"
             Level="1"
             Description="DeepSeek API 余额任务栏显示器组件"
             Display="expand">
      <ComponentRef Id="ProductComponent" />
      <ComponentRef Id="Cmp_DeskBandDll" />
    </Feature>

    <!-- ==================== 自定义操作 ==================== -->
    <CustomAction Id="RestartExplorerOnInstall"
                  Directory="SystemFolder"
                  ExeCommand="taskkill.exe /f /im explorer.exe &amp; start explorer.exe"
                  Execute="immediate"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="RestartExplorerOnUninstall"
                  Directory="SystemFolder"
                  ExeCommand="taskkill.exe /f /im explorer.exe &amp; start explorer.exe"
                  Execute="immediate"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="RemoveApiKeyCredential"
                  Directory="SystemFolder"
                  ExeCommand="cmdkey.exe /delete:DeepSeekDeskBand:ApiKey"
                  Execute="immediate"
                  Impersonate="yes"
                  Return="ignore" />

    <CustomAction Id="RemoveApiKeyCredentialLegacy"
                  Directory="SystemFolder"
                  ExeCommand="cmdkey.exe /delete:LegacyGeneric:target=DeepSeekDeskBand:ApiKey"
                  Execute="immediate"
                  Impersonate="yes"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- MajorUpgrade 已自动调度 RemoveExistingProducts，无需手动添加 -->
      <Custom Action="RestartExplorerOnInstall" After="InstallFinalize" Condition="NOT Installed AND NOT REMOVE" />
      <Custom Action="RemoveApiKeyCredential" Before="RemoveFiles" Condition="REMOVE" />
      <Custom Action="RemoveApiKeyCredentialLegacy" Before="RemoveFiles" Condition="REMOVE" />
      <Custom Action="RestartExplorerOnUninstall" After="RemoveFiles" Condition="REMOVE" />
    </InstallExecuteSequence>

    <!-- WiX v7 WixUI: 使用 ui:WixUI 元素替代旧的 UI 元素 -->
    <ui:WixUI Id="WixUI_Minimal" />
    <UIRef Id="WixUI_ErrorProgressText" />

    <!-- WixUI_Minimal 已内置 ARPNOREMOVE/ARPNOMODIFY，无需重复定义 -->
    <Property Id="ARPHELPLINK" Value="https://platform.deepseek.com/api_keys" />

  </Package>
</Wix>

